generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum TransactionType {
  INGRESO
  GASTO
}

enum BusitoStatus {
  ACTIVO
  INACTIVO
  EN_MANTENIMIENTO
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  busitos   Busito[]
}

model User {
  id             Int           @id @default(autoincrement())
  name           String
  email          String        @unique
  password       String
  role           Role          @default(USER)
  organizationId Int
  organization   Organization  @relation(fields: [organizationId], references: [id])
  locale         String        @default("es-PA")
  currency       String        @default("USD")
  createdAt      DateTime      @default(now())
  busitos        Busito[]
  transactions   Transaction[]
}

model Busito {
  id             Int           @id @default(autoincrement())
  name           String
  description    String?
  plateNumber    String?
  capacity       Int?
  model          String?
  year           Int?
  status         BusitoStatus  @default(ACTIVO)
  userId         Int
  organizationId Int
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
}

model Transaction {
  id          Int             @id @default(autoincrement())
  amount      Float
  description String
  type        TransactionType
  category    String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  userId      Int
  user        User            @relation(fields: [userId], references: [id])
  busitoId    Int
  busito      Busito          @relation(fields: [busitoId], references: [id], onDelete: Cascade)
}
